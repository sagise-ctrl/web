{
  "include": ["src/**/*", "api/**/*"],
  "exclude": ["node_modules", "build", "dist"],
  "compilerOptions": {
    "target": "ES2020",
    "noEmit": false,
    "jsx": "preserve",
    "lib": ["esnext", "dom", "dom.iterable"],
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "moduleResolution": "node",
    "module": "commonjs",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "vite/client"],
    "paths": { "@/*": ["./src/*"] }
  }
}
