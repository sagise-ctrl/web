{
  "buildCommand": "cd artifacts/jasa-tugas && vite build",
  "outputDirectory": "artifacts/jasa-tugas/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "functions": {},
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "x-middleware-skip",
          "value": "1"
        }
      ]
    }
  ]
}
